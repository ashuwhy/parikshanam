# Local: copy to .env.local (never commit secrets).
# Production (Vercel): Project → Settings → Environment Variables.
#   Add the same keys for Production AND Preview.
#   NEXT_PUBLIC_* are baked in at build time — redeploy after changing them.
#   SUPABASE_SERVICE_ROLE_KEY and RESEND_API_KEY must stay server-only (not NEXT_PUBLIC_).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
TEACHER_APP_URL=http://localhost:3003
