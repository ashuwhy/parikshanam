{
  "name": "parikshanam",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@parikshanam/api",
    "dev:mobile": "turbo dev --filter=@parikshanam/mobile",
    "dev:web": "turbo dev --filter=@parikshanam/web",
    "dev:admin": "turbo dev --filter=@parikshanam/admin",
    "dev:teacher": "turbo dev --filter=@parikshanam/teacher",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "supabase:push": "supabase db push",
    "supabase:link": "supabase link"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "react-native-reanimated": "4.2.1",
    "lightningcss": "1.30.1"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
