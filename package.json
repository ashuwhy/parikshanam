{
  "name": "parikshanam",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@parikshanam/api",
    "dev:mobile": "turbo dev --filter=@parikshanam/mobile",
    "dev:web": "turbo dev --filter=@parikshanam/web",
    "dev:admin": "turbo dev --filter=@parikshanam/admin",
    "dev:teacher": "turbo dev --filter=@parikshanam/teacher",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "supabase:push": "supabase db push",
    "supabase:link": "supabase link",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "react-native-reanimated": "4.2.1",
    "lightningcss": "1.30.1"
  },
  "packageManager": "npm@11.6.2"
}
